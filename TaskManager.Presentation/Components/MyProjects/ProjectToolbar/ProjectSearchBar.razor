 <input type="search"
           class="form-control flex-grow-1"
           placeholder="Filter projects..."
           value="@ProjectFilter"
           @oninput="HandleFilterChange" />


@code{

    [Parameter] public string ProjectFilter { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ProjectFilterChanged { get; set; }

    private async Task HandleFilterChange(ChangeEventArgs e)
    {
        var newValue = e.Value?.ToString() ?? string.Empty;
        await ProjectFilterChanged.InvokeAsync(newValue);
    }
}