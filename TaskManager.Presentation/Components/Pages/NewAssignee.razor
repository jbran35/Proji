@using BlazorBootstrap
@inherits AppComponentBase

<p>Email:</p>
<div>
    <div class="d-flex mb-3 gap-2">
        <input type="text"
               class="form-control"
               placeholder="johndoe@gmail.com"
               @bind="_email"
               disabled="@_assigneeFound" />

        <Button Color="ButtonColor.Dark" @onclick="SearchForUser" Disabled="@_assigneeFound"><Icon Name="IconName.Search" /></Button>

    </div>
</div>