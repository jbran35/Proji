@page "/login"
@using BlazorBootstrap
@using TaskManager.Presentation.Components.Layout
@layout LoginLayout
@inherits AppComponentBase

<title>Login</title>

<div class="container">
    <div class="d-flex flex-column align-items-center justify-content-start pt-5" style="min-height: 75vh;">

        <Card Class="w-50">
            <CardBody>
                <div class="text-center">
                    <CardTitle>Login</CardTitle>
                </div>

                <form method="post" action="/account/login">

                    <AntiforgeryToken />

                    <div class="form-group mb-3" >
                        <label>Username</label>
                        <input aria-label="UserName" type="text" name="username" class="form-control" required />
                    </div>

                    <div class="form-group mb-3">
                        <label>Password</label>
                        <input aria-label="Password" type="password" name="password" class="form-control" required />
                    </div>

                    <button type="submit" class="btn btn-dark w-100" aria-label="Login">Login</button>

                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="d-flex justify-content-center align-items-start pt-2">

                        <span class="text-danger">***@ErrorMessage***</span>

                        </div>
                    }
                </form>

            </CardBody>
        </Card>

        <div class="d-flex justify-content-center align-items-start pt-5">
            <p> Don't have an account yet? <NavLink aria-label="Register" href="/register" class="text-primary text-decoration-none fw-bold"> Sign Up </NavLink></p>
        </div>
    </div>
</div>


@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorMessage { get; set; }
}



